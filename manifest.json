{
  "short_name": "Ghost Link",
  "name": "Ghost Link — Peer Chat",
  "description": "Secure peer-to-peer encrypted chat. No servers. No logs. AES-256-GCM.",
  "id": "/index.html",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#00ff41",
  "background_color": "#000500",
  "categories": ["communications", "security"],
  "icons": [
    {
      "src": "icons/icon-144.svg",
      "type": "image/svg+xml",
      "sizes": "144x144",
      "purpose": "any"
    },
    {
      "src": "icons/icon-152.svg",
      "type": "image/svg+xml",
      "sizes": "152x152",
      "purpose": "any"
    },
    {
      "src": "icons/icon-192.svg",
      "type": "image/svg+xml",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512.svg",
      "type": "image/svg+xml",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Open Tunnel",
      "short_name": "Create",
      "description": "Generate an access key and open a secure chat line",
      "url": "./index.html?action=create",
      "icons": [{ "src": "icons/icon-192.svg", "sizes": "192x192" }]
    },
    {
      "name": "Enter Tunnel",
      "short_name": "Join",
      "description": "Enter an existing access key to link with a peer",
      "url": "./index.html?action=join",
      "icons": [{ "src": "icons/icon-192.svg", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "./index.html?share-target=1",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
